# .env로 복사해서 실제 값 채우기 (cp .env.example .env). .env는 절대 커밋하지 말 것.

# 소스 DB (읽기 전용) — 원본 인스타그램/유튜브 포스트
SRC_DB_HOST=
SRC_DB_PORT=3306
SRC_DB_USER=
SRC_DB_PASSWORD=
SRC_DB_NAME=hifen

# 타겟 DB (쓰기) — 공구왕 gonggu_post / gonggu_product
DST_DB_HOST=
DST_DB_PORT=3306
DST_DB_USER=
DST_DB_PASSWORD=
DST_DB_NAME=dev_gongguking

# Dify — LLM#1(공구판별/상품추출) API 키
DIFY_URL=https://api.dify.ai/v1
DIFY_KEY=

# Dify — resolve_links.py(링크 해석 단계, 4.5단계)용 API 키 2개
# LLM#2 "공구왕 링크선택" (dify_workflows/02_link_selection.yml)
DIFY_KEY_PICK=
# LLM#3 "공구왕 페이지판별" (dify_workflows/03_page_judge.yml)
DIFY_KEY_JUDGE=
